@page "/"
@page "/bot"
@page "/bot-portrait"
@implements IAsyncDisposable
@rendermode InteractiveServer
@using Microsoft.AspNetCore.SignalR.Client
@using Tobot.Web.Hubs
@inject NavigationManager Navigation
@inject Tobot.Device.TobotController Controller

<PageTitle>Tobot Bot</PageTitle>

<div class="bot-screen @GetMoodClass()" @onclick="HandleFullscreenClick">
    <div class="distance-indicator">@_distanceText</div>

    <div class="feature-stage">
        <div class="eyes-row">
            <div class="eye-wrapper left-eye">
                <div class="eye">
                    <div class="eyeball">
                        <div class="pupil"></div>
                        <div class="shine"></div>
                    </div>
                    <div class="eyelid"></div>
                </div>
            </div>

            <div class="eye-wrapper right-eye">
                <div class="eye">
                    <div class="eyeball">
                        <div class="pupil"></div>
                        <div class="shine"></div>
                    </div>
                    <div class="eyelid"></div>
                </div>
            </div>
        </div>

        <div class="nose" aria-hidden="true"></div>

        <div class="mouth-zone">
            <div class="mouth">
                <div class="mouth-inner">
                    <div class="tongue"></div>
                    <div class="tooth tooth-left"></div>
                    <div class="tooth tooth-right"></div>
                </div>
                <div class="mouth-cheek-line left"></div>
                <div class="mouth-cheek-line right"></div>
            </div>
        </div>

    </div>
</div>

<div class="status-bar">
    <span>@_wifiSsidDisplay</span>
    <span>- @_wifiIpDisplay</span>
    <span>- CPU @_cpuLoadDisplay</span>
    <span>- MEM @_memLoadDisplay</span>
</div>

<style>
    html,
    body {
        margin: 0;
        width: 100%;
        height: 100%;
        overflow: hidden;
        background: #130f1f;
    }

    * {
        box-sizing: border-box;
    }

    .bot-screen {
        --bg1: #1d1536;
        --bg2: #100b23;
        --shell: #fff9ff;
        --shell-outline: #ffcde9;
        --eye-white: #ffffff;
        --pupil-a: #3f2a65;
        --pupil-b: #181129;
        --accent-a: #ff8ec7;
        --accent-b: #8be7ff;
        --mouth-main: #45234f;
        --mouth-inner: #7c3d7d;
        --tongue: #ff77b3;

        width: 720px;
        height: 1280px;
        position: fixed;
        top: 0;
        left: 0;
        display: grid;
        place-items: center;
        background:
            radial-gradient(1200px 900px at 50% -10%, rgba(255, 148, 205, 0.35), transparent 55%),
            radial-gradient(900px 800px at 10% 100%, rgba(122, 211, 255, 0.28), transparent 60%),
            linear-gradient(180deg, var(--bg1) 0%, var(--bg2) 100%);
        overflow: hidden;
        cursor: pointer;
    }

    .distance-indicator {
        position: absolute;
        top: 26px;
        left: 26px;
        padding: 9px 14px;
        border-radius: 999px;
        border: 2px solid rgba(255, 255, 255, 0.26);
        background: rgba(10, 8, 22, 0.55);
        color: #d7f7ff;
        font-family: "Comic Sans MS", "Trebuchet MS", sans-serif;
        font-size: 24px;
        letter-spacing: 0.5px;
        box-shadow: 0 0 18px rgba(139, 231, 255, 0.45);
        z-index: 5;
    }

    .feature-stage {
        width: 620px;
        height: 860px;
        position: relative;
    }

    .eyes-row {
        position: absolute;
        top: 170px;
        left: 50%;
        transform: translateX(-50%);
        width: 540px;
        display: flex;
        justify-content: space-between;
    }

    .eye-wrapper {
        position: relative;
        width: 250px;
        height: 250px;
        animation: eye-wrapper-bob 3.2s ease-in-out infinite;
    }

    .right-eye {
        animation-delay: 0.12s;
    }

    .eye {
        position: relative;
        width: 100%;
        height: 100%;
        border-radius: 50%;
        background: var(--eye-white);
        box-shadow:
            0 0 24px rgba(255, 255, 255, 0.7),
            inset 0 -16px 24px rgba(93, 56, 122, 0.1);
        overflow: hidden;
    }

    .eyeball {
        position: absolute;
        inset: 0;
        animation: look-around 5.5s ease-in-out infinite;
    }

    .pupil {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 78px;
        height: 78px;
        border-radius: 50%;
        background: radial-gradient(circle at 32% 30%, var(--pupil-a) 0%, var(--pupil-b) 78%);
        box-shadow: 0 0 12px rgba(24, 17, 41, 0.6);
    }

    .pupil::after {
        content: "";
        position: absolute;
        top: 20px;
        left: 20px;
        width: 18px;
        height: 18px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.95);
    }

    .shine {
        position: absolute;
        top: 58px;
        left: 72px;
        width: 30px;
        height: 30px;
        border-radius: 50%;
        background: radial-gradient(circle at center, rgba(255, 255, 255, 0.95), rgba(255, 255, 255, 0.25) 65%, transparent 80%);
    }

    .eyelid {
        position: absolute;
        top: -250px;
        left: 0;
        width: 100%;
        height: 100%;
        border-radius: 50%;
        background: linear-gradient(180deg, #ffd4eb 0%, #fff2fa 100%);
        border-bottom: 3px solid #ffb3dc;
        animation: blink-eyelid 3.8s ease-in-out infinite;
    }

    .right-eye .eyelid {
        animation-delay: 0.08s;
    }

    .mouth-zone {
        position: absolute;
        left: 50%;
        top: 560px;
        transform: translateX(-50%);
        width: 320px;
        height: 170px;
        display: grid;
        place-items: center;
    }

    .nose {
        position: absolute;
        left: 50%;
        top: 490px;
        width: 24px;
        height: 18px;
        transform: translateX(-50%);
        border-radius: 50% 50% 62% 62%;
        background: linear-gradient(180deg, #ff9ac6 0%, #e870a7 100%);
        box-shadow: 0 0 10px rgba(255, 141, 191, 0.45);
        opacity: 0.9;
    }

    .nose::after {
        content: "";
        position: absolute;
        top: 4px;
        left: 8px;
        width: 8px;
        height: 5px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.7);
    }

    .mouth {
        width: 220px;
        height: 118px;
        position: relative;
        border: 5px solid var(--mouth-main);
        border-top: 0;
        border-radius: 0 0 110px 110px;
        background: linear-gradient(180deg, #2d1635 0%, #1f1128 100%);
        box-shadow: inset 0 -8px 16px rgba(0, 0, 0, 0.35);
        animation: mouth-neutral 2.8s ease-in-out infinite;
        overflow: hidden;
    }

    .mouth-inner {
        position: absolute;
        inset: 14px 14px 10px;
        border-radius: 0 0 86px 86px;
        background: linear-gradient(180deg, var(--mouth-inner) 0%, #5f2f6b 100%);
        overflow: hidden;
    }

    .tongue {
        position: absolute;
        bottom: -2px;
        left: 50%;
        transform: translateX(-50%);
        width: 98px;
        height: 56px;
        border-radius: 56px 56px 18px 18px;
        background: linear-gradient(180deg, var(--tongue) 0%, #ff4f9f 100%);
    }

    .tooth {
        position: absolute;
        top: 0;
        width: 20px;
        height: 20px;
        background: #fff;
        border-radius: 0 0 10px 10px;
    }

    .tooth-left {
        left: 74px;
    }

    .tooth-right {
        right: 74px;
    }

    .mouth-cheek-line {
        position: absolute;
        top: 62px;
        width: 22px;
        height: 14px;
        border-bottom: 4px solid #a85283;
        border-radius: 0 0 20px 20px;
    }

    .mouth-cheek-line.left {
        left: -16px;
        transform: rotate(14deg);
    }

    .mouth-cheek-line.right {
        right: -16px;
        transform: rotate(-14deg);
    }

    .status-bar {
        position: fixed;
        bottom: 14px;
        left: 14px;
        right: 14px;
        display: flex;
        gap: 10px;
        justify-content: center;
        flex-wrap: wrap;
        color: rgba(235, 246, 255, 0.92);
        font-family: "Trebuchet MS", "Comic Sans MS", sans-serif;
        font-size: 16px;
        letter-spacing: 0.2px;
        opacity: 0.85;
        pointer-events: none;
        text-shadow: 0 0 10px rgba(0, 0, 0, 0.6);
    }

    .bot-screen.mood-happy .eye {
        border-radius: 50% 50% 40% 40%;
        transform: scaleY(0.8);
        background: linear-gradient(180deg, #ffffff 0%, #fff3c9 100%);
    }

    .bot-screen.mood-happy .pupil {
        width: 52px;
        height: 52px;
        animation: happy-sparkle 0.75s ease-in-out infinite;
    }

    .bot-screen.mood-happy .eyeball {
        animation: look-happy 1s ease-in-out infinite;
    }

    .bot-screen.mood-happy .mouth {
        width: 280px;
        height: 150px;
        border-color: #5a2a6b;
        animation: mouth-happy 0.7s ease-in-out infinite;
    }

    .bot-screen.mood-happy .tongue {
        animation: tongue-bounce 0.7s ease-in-out infinite;
    }

    .bot-screen.mood-happy .nose {
        transform: translateX(-50%) scale(1.08);
        filter: brightness(1.08);
    }

    .bot-screen.mood-terrified .eye {
        transform: scale(1.15);
        box-shadow: 0 0 34px rgba(147, 201, 255, 0.75), inset 0 -18px 26px rgba(55, 109, 180, 0.18);
    }

    .bot-screen.mood-terrified .pupil {
        width: 102px;
        height: 102px;
        background: radial-gradient(circle at 32% 30%, #1b1b2b 0%, #000 100%);
        animation: dilate 0.45s ease-in-out infinite alternate;
    }

    .bot-screen.mood-terrified .eyeball {
        animation: panic-dart 0.23s linear infinite;
    }

    .bot-screen.mood-terrified .eyelid {
        animation: none;
        top: -300px;
    }

    .bot-screen.mood-terrified .mouth {
        width: 150px;
        height: 160px;
        border-radius: 80px;
        border-top: 6px solid var(--mouth-main);
        animation: mouth-gasp 0.18s ease-in-out infinite alternate;
    }

    .bot-screen.mood-terrified .mouth-inner {
        inset: 18px;
        border-radius: 70px;
    }

    .bot-screen.mood-terrified .tongue,
    .bot-screen.mood-terrified .tooth,
    .bot-screen.mood-terrified .mouth-cheek-line,
    .bot-screen.mood-terrified .nose {
        opacity: 0;
    }

    .bot-screen.mood-angry .eye {
        border-radius: 45% 45% 55% 55%;
        background: linear-gradient(180deg, #ffe3e3 0%, #ffc3c3 100%);
        box-shadow: 0 0 28px rgba(255, 100, 100, 0.66), inset 0 -14px 24px rgba(173, 30, 30, 0.2);
    }

    .bot-screen.mood-angry .eyeball {
        animation: look-angry 0.45s ease-in-out infinite;
    }

    .bot-screen.mood-angry .pupil {
        width: 38px;
        height: 58px;
        border-radius: 48%;
        background: radial-gradient(circle at 35% 35%, #780f0f 0%, #130606 100%);
    }

    .bot-screen.mood-angry .eyelid {
        top: -180px;
        transform: rotate(-14deg);
    }

    .bot-screen.mood-angry .mouth {
        width: 250px;
        height: 86px;
        border-top: 6px solid var(--mouth-main);
        border-bottom: 6px solid var(--mouth-main);
        border-radius: 28px;
        animation: mouth-grr 0.4s linear infinite;
    }

    .bot-screen.mood-angry .nose {
        filter: saturate(1.4) brightness(0.9);
    }

    .bot-screen.mood-angry .mouth-inner {
        border-radius: 20px;
        inset: 14px 12px;
        background: repeating-linear-gradient(
            -45deg,
            #7a2f43,
            #7a2f43 12px,
            #9e3f58 12px,
            #9e3f58 24px
        );
    }

    .bot-screen.mood-angry .tongue {
        opacity: 0;
    }

    @@keyframes eye-wrapper-bob {
        0%,
        100% {
            transform: translateY(0px);
        }

        50% {
            transform: translateY(-8px);
        }
    }

    @@keyframes look-around {
        0%,
        100% {
            transform: translate(0, 0);
        }

        20% {
            transform: translate(-5px, -6px);
        }

        40% {
            transform: translate(5px, -4px);
        }

        60% {
            transform: translate(-4px, 5px);
        }

        80% {
            transform: translate(4px, 4px);
        }
    }

    @@keyframes blink-eyelid {
        0%,
        89%,
        100% {
            top: -230px;
        }

        92%,
        95% {
            top: 0;
        }
    }

    @@keyframes mouth-neutral {
        0%,
        100% {
            transform: scaleY(1) translateY(0);
        }

        50% {
            transform: scaleY(0.93) translateY(2px);
        }
    }

    @@keyframes happy-sparkle {
        0%,
        100% {
            transform: scale(1);
            opacity: 1;
        }

        50% {
            transform: scale(1.3);
            opacity: 0.8;
        }
    }

    @@keyframes look-happy {
        0%,
        100% {
            transform: translate(-50%, -50%) rotate(-8deg) scale(1.05);
        }

        25% {
            transform: translate(-45%, -48%) rotate(8deg) scale(1.08);
        }

        75% {
            transform: translate(-55%, -52%) rotate(-8deg) scale(1.05);
        }
    }

    @@keyframes mouth-happy {
        0%,
        100% {
            transform: scale(1) translateY(0);
        }

        50% {
            transform: scale(1.04, 1.08) translateY(-4px);
        }
    }

    @@keyframes tongue-bounce {
        0%,
        100% {
            transform: translateX(-50%) translateY(0);
        }

        50% {
            transform: translateX(-50%) translateY(-6px);
        }
    }

    @@keyframes dilate {
        0% {
            transform: translate(-50%, -50%) scale(0.95);
        }

        100% {
            transform: translate(-50%, -50%) scale(1.16);
        }
    }

    @@keyframes panic-dart {
        0% {
            transform: translate(0, 0);
        }

        20% {
            transform: translate(-10px, -8px);
        }

        40% {
            transform: translate(9px, -6px);
        }

        60% {
            transform: translate(-8px, 9px);
        }

        80% {
            transform: translate(8px, 7px);
        }

        100% {
            transform: translate(-5px, -7px);
        }
    }

    @@keyframes mouth-gasp {
        0% {
            transform: scale(1);
        }

        100% {
            transform: scale(1.06);
        }
    }

    @@keyframes look-angry {
        0%,
        100% {
            transform: translate(0, -6px);
        }

        50% {
            transform: translate(0, -2px);
        }
    }

    @@keyframes mouth-grr {
        0%,
        100% {
            transform: translateX(0);
        }

        25% {
            transform: translateX(-2px);
        }

        75% {
            transform: translateX(2px);
        }
    }

</style>

@code {
    private enum Mood
    {
        Neutral,
        Happy,
        Terrified,
        Angry
    }

    private Mood _currentMood = Mood.Neutral;

    private string _distanceText = "-- cm";
    private HubConnection? _hubConnection;
    private double? _lastDistance;
    private CancellationTokenSource? _neutralCts;
    private Task? _randomDriveTask;
    private bool _isRandomDriveActive;

    private string _wifiSsidDisplay = "Wi‑Fi: --";
    private string _wifiIpDisplay = "IP: --";
    private string _cpuLoadDisplay = "--%";
    private string _memLoadDisplay = "--%";

    private string GetMoodClass()
    {
        return _currentMood switch
        {
            Mood.Happy => "mood-happy",
            Mood.Terrified => "mood-terrified",
            Mood.Angry => "mood-angry",
            _ => "mood-neutral"
        };
    }

    protected override async Task OnInitializedAsync()
    {
        _hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/tobothub"))
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<double>(TobotHubEvents.DistanceChanged, cm =>
        {
            _distanceText = $"{cm:F1} cm";

            var previous = _lastDistance;
            _lastDistance = cm;

            _neutralCts?.Cancel();
            _neutralCts?.Dispose();
            _neutralCts = null;

            if (cm < 10.0)
            {
                _currentMood = Mood.Angry;
            }
            else if (previous.HasValue && cm > previous.Value)
            {
                _currentMood = Mood.Happy;

                var cts = new CancellationTokenSource();
                _neutralCts = cts;
                _ = ResetToNeutralAfterDelayAsync(cts.Token);
            }

            InvokeAsync(StateHasChanged);
        });

        _hubConnection.On<string?, string?, double, double>(TobotHubEvents.PiStatusUpdated, (ssid, ip, cpuPct, memPct) =>
        {
            _wifiSsidDisplay = $"Wi‑Fi: {ssid ?? "(not connected)"}";
            _wifiIpDisplay = $"IP: {ip ?? "(none)"}";
            _cpuLoadDisplay = $"{cpuPct:F0}%";
            _memLoadDisplay = $"{memPct:F0}%";
            InvokeAsync(StateHasChanged);
        });

        try
        {
            await _hubConnection.StartAsync();
        }
        catch
        {
            _distanceText = "(no hub)";
        }
    }

    private async Task ResetToNeutralAfterDelayAsync(CancellationToken cancellationToken)
    {
        try
        {
            await Task.Delay(TimeSpan.FromSeconds(5), cancellationToken).ConfigureAwait(false);
            _currentMood = Mood.Neutral;
            await InvokeAsync(StateHasChanged);
        }
        catch (TaskCanceledException)
        {
        }
    }

    private void HandleFullscreenClick()
    {
        if (_isRandomDriveActive)
        {
            Controller.StopRandomDrive();
            _isRandomDriveActive = false;
            return;
        }

        _randomDriveTask = Controller.StartRandomDrive(
            forwardSpeed: 50,
            turnSpeed: 40,
            obstacleDistanceCm: 20.0,
            clearDistanceCm: 30.0);

        _isRandomDriveActive = true;
    }

    public async ValueTask DisposeAsync()
    {
        _neutralCts?.Cancel();
        _neutralCts?.Dispose();

        Controller.StopRandomDrive();
        _isRandomDriveActive = false;

        if (_randomDriveTask is not null)
        {
            try
            {
                await _randomDriveTask.ConfigureAwait(false);
            }
            catch
            {
            }
        }

        if (_hubConnection is not null)
        {
            try
            {
                await _hubConnection.StopAsync().ConfigureAwait(false);
            }
            catch
            {
            }

            await _hubConnection.DisposeAsync().ConfigureAwait(false);
        }
    }
}
